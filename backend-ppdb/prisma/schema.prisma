generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Jalur {
  ZONASI
  DOMISILI
  PRESTASI
  AFIRMASI
}

enum StatusPendaftaran {
  MENUNGGU
  DIPROSES_1
  DITOLAK_1
  DIPROSES_2
  DITERIMA
  DITOLAK
}

enum StatusPilihan {
  MENUNGGU
  DIPROSES
  DITERIMA
  DITOLAK
}

enum StatusFinal {
  DITERIMA
  DITOLAK
}

// 🔥 OPTIONAL (untuk dokumen lebih real)
enum TipeDokumen {
  KK
  AKTA
  RAPOR
  PRESTASI
}


model User {
  id        String   @id @default(uuid())
  nama      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  noTlpn    String

  alamat    String?
  kelurahan String?
  kecamatan String?
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminSekolah AdminSekolah?
  pendaftaran  Pendaftaran?
  pengumuman   Pengumuman[]
  verifikasi   VerifikasiLog[]
}

model Sekolah {
  id        String   @id @default(uuid())
  nama      String   @unique
  alamat    String
  latitude  Float
  longitude Float
  kuota     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminSekolah AdminSekolah?
  pilihan      PilihanSekolah[]
  hasil        HasilSeleksi[]
}

model AdminSekolah {
  id         String  @id @default(uuid())
  userId     String  @unique
  sekolahId  String  @unique

  user    User    @relation(fields: [userId], references: [id])
  sekolah Sekolah @relation(fields: [sekolahId], references: [id])
}

model Pendaftaran {
  id        String   @id @default(uuid())
  userId    String   @unique

  jalur     Jalur
  status    StatusPendaftaran @default(MENUNGGU)

  nilaiRapor    Float?
  nilaiPrestasi Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User             @relation(fields: [userId], references: [id])
  pilihan    PilihanSekolah[]
  dokumen    Dokumen[]
  hasil      HasilSeleksi?
  pengumuman Pengumuman[]
  verifikasi VerifikasiLog[]
}

model PilihanSekolah {
  id            String   @id @default(uuid())
  pendaftaranId String
  sekolahId     String

  pilihanKe     Int
  status        StatusPilihan @default(MENUNGGU)

  jarak         Float?

  isLocked      Boolean @default(false)
  alasanPenolakan String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
  sekolah     Sekolah     @relation(fields: [sekolahId], references: [id])

  @@unique([pendaftaranId, pilihanKe])
}

enum StatusDokumen {
  MENUNGGU
  DITERIMA
  DITOLAK
}

model Dokumen {
  id             String   @id @default(uuid())
  pendaftaranId  String

  namaFile       String
  urlFile        String
  tipe           String     // mimetype
  ukuran         Int        // size file (byte)
  tipeDokumen    TipeDokumen?

  status         StatusDokumen @default(MENUNGGU) // ubah ke enum

  createdAt      DateTime @default(now())

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])

  @@index([pendaftaranId])
}

model HasilSeleksi {
  id                String   @id @default(uuid())
  pendaftaranId     String   @unique
  sekolahDiterimaId String?

  statusFinal       StatusFinal
  catatan           String?

  createdAt DateTime @default(now())

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
  sekolah     Sekolah?    @relation(fields: [sekolahDiterimaId], references: [id])
}

model VerifikasiLog {
  id            String   @id @default(uuid())
  pendaftaranId String
  actorId       String

  role          Role
  status        String
  catatan       String?

  createdAt DateTime @default(now())

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
  actor       User        @relation(fields: [actorId], references: [id])
}

model Pengumuman {
  id            String   @id @default(uuid())
  userId        String
  pendaftaranId String

  judul         String
  pesan         String

  createdAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
}