generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Jalur {
  ZONASI
  DOMISILI
  PRESTASI
  AFIRMASI
}

enum StatusPendaftaran {
  MENUNGGU
  DIPROSES_1
  DITOLAK_1
  DIPROSES_2
  DITERIMA
  DITOLAK
}

enum StatusPilihan {
  MENUNGGU
  DIPROSES
  DITERIMA
  DITOLAK
}

enum StatusFinal {
  DITERIMA
  DITOLAK
}

model User {
  id        String   @id @default(uuid())
  nama      String
  email     String   @unique
  password  String
  role      Role     @default(USER)

  // alamat & geolokasi
  alamat    String?
  kelurahan String?
  kecamatan String?
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminSekolah AdminSekolah?
  pendaftaran  Pendaftaran?
  pengumuman   Pengumuman[]
  verifikasi   VerifikasiLog[]
}

model Sekolah {
  id        String   @id @default(uuid())
  nama      String   @unique
  alamat    String
  latitude  Float
  longitude Float
  kuota     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminSekolah AdminSekolah?
  pilihan      PilihanSekolah[]
  hasil        HasilSeleksi[]
}

model AdminSekolah {
  id         String  @id @default(uuid())
  userId     String  @unique
  sekolahId  String  @unique

  user       User    @relation(fields: [userId], references: [id])
  sekolah    Sekolah @relation(fields: [sekolahId], references: [id])
}

model Pendaftaran {
  id        String   @id @default(uuid())
  userId    String   @unique

  jalur     Jalur
  status    StatusPendaftaran @default(MENUNGGU)

  // khusus jalur prestasi
  nilaiRapor     Float?
  nilaiPrestasi  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User             @relation(fields: [userId], references: [id])
  pilihan    PilihanSekolah[]
  dokumen    Dokumen[]
  hasil      HasilSeleksi?
  pengumuman Pengumuman[]
  verifikasi VerifikasiLog[]
}

model PilihanSekolah {
  id              String   @id @default(uuid())
  pendaftaranId   String
  sekolahId       String

  pilihanKe       Int      // 1 atau 2
  status          StatusPilihan @default(MENUNGGU)

  // khusus zonasi
  jarak           Float?

  // cascading control
  isLocked        Boolean @default(false)

  alasanPenolakan String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
  sekolah     Sekolah     @relation(fields: [sekolahId], references: [id])

  @@unique([pendaftaranId, pilihanKe])
}

model Dokumen {
  id             String   @id @default(uuid())
  pendaftaranId  String

  namaFile       String
  urlFile        String

  createdAt DateTime @default(now())

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
}

model HasilSeleksi {
  id                  String   @id @default(uuid())
  pendaftaranId       String   @unique
  sekolahDiterimaId   String?

  statusFinal         StatusFinal
  catatan             String?

  createdAt DateTime @default(now())

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
  sekolah     Sekolah?    @relation(fields: [sekolahDiterimaId], references: [id])
}

model VerifikasiLog {
  id              String   @id @default(uuid())
  pendaftaranId   String
  actorId         String

  role            Role
  status          String
  catatan         String?

  createdAt DateTime @default(now())

  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
  actor       User        @relation(fields: [actorId], references: [id])
}

model Pengumuman {
  id             String   @id @default(uuid())
  userId         String
  pendaftaranId  String

  judul          String
  pesan          String

  createdAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])
}